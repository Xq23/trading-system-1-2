PORT=8787
JWT_SECRET=请换成随机长字符串
# 逗号分隔的前端域名，例如 Vercel / Netlify 地址
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5500
# SQLite 路径（Railway 可挂载卷后设为 /data/ts12.db）
DATABASE_PATH=./data/ts12.db
# 可选：币安 U 本位 API 根地址，多个用逗号分隔（默认自动轮换 fapi/fapi1/fapi2/fapi3）
# BINANCE_FAPI_BASES=https://fapi.binance.com,https://fapi1.binance.com
